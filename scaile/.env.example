# GitLab
GITLAB_ROOT_PASSWORD=changeme
GITLAB_URL=http://localhost:8090
GITLAB_TOKEN=               # generated after first login

# n8n
N8N_ENCRYPTION_KEY=changeme-32-chars-min
N8N_POSTGRES_PASSWORD=n8n_secret
N8N_OWNER_EMAIL=admin@local.host
N8N_OWNER_PASSWORD=changeme
N8N_API_KEY=                # generate in n8n → Settings → API

# GitLab URL from within Docker network (used by n8n workflow)
GITLAB_INTERNAL_URL=http://gitlab:80

# Chat webhook (Slack / Discord / Teams incoming webhook URL)
CHAT_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# AI (OpenAI-compatible, swap to Ollama later)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o

# Claude Code (webhook server for issue breakdown)
ANTHROPIC_API_KEY=sk-ant-...
