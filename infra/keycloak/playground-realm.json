{
  "realm": "playground",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "permanentLockout": false,
  "clients": [
    {
      "clientId": "playground-api",
      "name": "Backend API (Gateway / .NET)",
      "description": "Confidential client for API resource; used as audience in JWT validation",
      "enabled": true,
      "publicClient": false,
      "redirectUris": [],
      "webOrigins": [],
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "ordering-web",
      "name": "Ordering Web (Angular SPA)",
      "description": "Public client for Angular frontend",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:4200/*",
        "http://127.0.0.1:4200/*"
      ],
      "webOrigins": [
        "http://localhost:4200",
        "http://127.0.0.1:4200"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Default role for authenticated users"
      }
    ]
  },
  "defaultRoles": ["user"]
}
