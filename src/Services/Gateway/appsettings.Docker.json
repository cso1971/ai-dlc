{
  "OpenTelemetry": {
    "Endpoint": "http://jaeger:4317"
  },
  "Authentication": {
    "Authority": "http://keycloak:8080/realms/playground",
    "Audience": "playground-api",
    "RequireHttpsMetadata": false
  },
  "ReverseProxy": {
    "Clusters": {
      "ordering-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://ordering-api:8080"
          }
        }
      },
      "customers-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://customers-api:8080"
          }
        }
      },
      "invoicing-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://invoicing-api:8080"
          }
        }
      },
      "orchestrator-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://host.docker.internal:5020"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://host.docker.internal:5010"
          }
        }
      }
    }
  }
}
