{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Authentication": {
    "Authority": "http://localhost:8180/realms/playground",
    "Audience": "playground-api",
    "RequireHttpsMetadata": false
  },
  "ReverseProxy": {
    "Routes": {
      "ordering": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/api/orders/{**catch-all}"
        }
      },
      "ordering-metrics": {
        "ClusterId": "ordering-cluster",
        "Match": {
          "Path": "/api/metrics/{**catch-all}"
        }
      },
      "customers": {
        "ClusterId": "customers-cluster",
        "Match": {
          "Path": "/api/customers/{**catch-all}"
        }
      },
      "invoicing": {
        "ClusterId": "invoicing-cluster",
        "Match": {
          "Path": "/api/invoices/{**catch-all}"
        }
      },
      "orchestrator": {
        "ClusterId": "orchestrator-cluster",
        "Match": {
          "Path": "/api/orchestrator/{**catch-all}"
        }
      },
      "ai": {
        "ClusterId": "ai-cluster",
        "Match": {
          "Path": "/api/ai/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "ordering-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "customers-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5003"
          }
        }
      },
      "invoicing-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5002"
          }
        }
      },
      "orchestrator-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5020"
          }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5010"
          }
        }
      }
    }
  }
}
